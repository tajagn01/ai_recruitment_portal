generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  phone             String?
  skills            String
  experienceYears   Int                @default(0)
  location          String?
  education         String?
  resumeText        String
  resumeFileUrl     String?
  resumePdfData     String?  // Base64-encoded PDF
  resumeHash        String?
  contentHash       String?
  resumeEmbedding   Json?
  duplicateFlag     Boolean            @default(false)
  pipelineStatus    String             @default("Applied")
  linkedin          String?
  github            String?
  portfolio         String?
  website           String?
  twitter           String?
  summary           String?
  candidateScore    Int                @default(0)
  rating            Int?
  employmentHistory String?
  certifications    String?
  languages         String?
  salaryExpectation Int?
  availability      String             @default("Available")
  interviewNotes    String?
  feedback          String?
  rejectionReason   String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  source            String             @default("Email")
  deduplicationLogs DeduplicationLog[]
  resumes           Resume[]

  @@index([resumeHash])
  @@index([contentHash])
}

model EmailSettings {
  id                String    @id @default(cuid())
  gmailClientId     String
  gmailClientSecret String
  gmailRefreshToken String
  isConnected       Boolean   @default(false)
  lastSyncAt        DateTime?
  lastSyncStatus    String?
  lastSyncMessage   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Resume {
  id                  String             @id @default(cuid())
  candidateId         String
  documentPath        String
  extractedData       Json
  uploadedAt          DateTime           @default(now())
  uploadedBy          String?
  version             Int                @default(1)
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  similarResumeInLogs DeduplicationLog[] @relation("mostSimilarResume")
  newResumeInLogs     DeduplicationLog[] @relation("newResume")
  candidate           Candidate          @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([isActive])
}

model DeduplicationLog {
  id                   String    @id @default(cuid())
  candidateId          String
  newResumeId          String
  mostSimilarResumeId  String?
  similarityScore      Float
  differencePercentage Float
  decision             String
  timestamp            DateTime  @default(now())
  userId               String?
  createdAt            DateTime  @default(now())
  candidate            Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  mostSimilarResume    Resume?   @relation("mostSimilarResume", fields: [mostSimilarResumeId], references: [id])
  newResume            Resume    @relation("newResume", fields: [newResumeId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([timestamp])
}
